# Local / Vercel MVP

# Durable DB on Vercel — set USE_SUPABASE=true after running supabase/mvp-enable.sql
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
USE_SUPABASE=true

# Optional (preferred): service role bypasses RLS — never expose to the browser
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

NEXT_PUBLIC_DEV_MODE=true
